flowchart TB
    subgraph Pattern["Syntactic / Pattern matching"]
        P1[AST + regex-like rules]
        P2[Fast, low setup]
        P3[Misses data flow across functions]
    end
    subgraph Taint["Taint / Data-flow analysis"]
        T1[Source to sink tracking]
        T2[Catches injection across files]
        T3[Slower, needs build context]
    end
    subgraph Semantic["Semantic / Symbolic"]
        S1[Path-sensitive reasoning]
        S2[Fewer false positives on logic bugs]
        S3[Heaviest compute]
    end

    Pattern -->|"depth increases"| Taint --> Semantic
    Pattern -.->|"speed decreases"| Semantic

