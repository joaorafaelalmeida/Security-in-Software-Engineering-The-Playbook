flowchart TB
    dockerfile["Pinned minimal base image<br/>and multi-stage Dockerfile"]
    nonroot["Non-root user<br/>small final image"]
    lint["Dockerfile lint<br/>Hadolint"]
    sbom["SBOM generation"]
    scan["CVE and secret scan<br/>Trivy or Grype"]
    decision{"Blocking findings?"}
    fail["Fail build<br/>triage and fix"]
    sign["Sign image<br/>Cosign + provenance"]
    registry["Push immutable digest<br/>to registry"]
    admission["Verify signature<br/>at admission"]
    deploy["Deploy workload"]

    dockerfile --> nonroot --> lint --> sbom --> scan --> decision
    decision -- yes --> fail
    decision -- no --> sign --> registry --> admission --> deploy

    classDef step fill:#e8f0fe,stroke:#2f3a4a,color:#1f2933
    classDef gate fill:#fff4e5,stroke:#2f3a4a,color:#1f2933
    classDef failClass fill:#fce8e6,stroke:#2f3a4a,color:#1f2933
    classDef pass fill:#e6f4ea,stroke:#2f3a4a,color:#1f2933

    class dockerfile,nonroot,lint,sbom,scan step
    class decision gate
    class fail failClass
    class sign,registry,admission,deploy pass
