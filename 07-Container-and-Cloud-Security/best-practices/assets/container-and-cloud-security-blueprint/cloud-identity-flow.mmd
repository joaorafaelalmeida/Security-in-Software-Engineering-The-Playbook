flowchart TB
    pod["Workload<br/>Kubernetes service account"]
    federation["Workload identity<br/>IRSA / GCP WI / Azure MI"]
    role["Cloud IAM role<br/>least privilege"]
    conditions["Conditions<br/>resource scope, audience, TTL"]
    service["Cloud resource<br/>bucket, KMS, database"]
    audit["Access review<br/>unused permissions"]

    pod --> federation --> role --> conditions --> service --> audit
    audit -. remove excess .-> role

