flowchart TB
    subgraph workload["Workload boundary"]
        direction LR
        process["Container process"]
        runtime["OCI runtime<br/>runc / crun / runsc"]
    end

    subgraph controls["Kernel isolation controls"]
        direction LR
        namespaces["Namespaces"]
        resources["cgroups v2"]
        syscalls["seccomp + capabilities"]
        mac["AppArmor / SELinux"]
    end

    kernel["Shared Linux kernel"]

    process --> runtime
    runtime --> namespaces
    runtime --> resources
    runtime --> syscalls
    runtime --> mac
    namespaces --> kernel
    resources --> kernel
    syscalls --> kernel
    mac --> kernel

    classDef process fill:#e6f4ea,stroke:#2f3a4a,color:#1f2933
    classDef control fill:#e8f0fe,stroke:#2f3a4a,color:#1f2933
    classDef boundary fill:#fff4e5,stroke:#2f3a4a,color:#1f2933

    class process process
    class runtime,namespaces,resources,syscalls,mac control
    class kernel boundary
