flowchart LR
    U[External User]
    B[Web Browser]

    subgraph TB1[Public Internet]
        WAF[WAF or Reverse Proxy]
    end

    subgraph TB2[Application Zone]
        WEB[Web Frontend]
        API[Backend API]
        AUTH[Identity Provider]
    end

    subgraph TB3[Data Zone]
        DB[(Application Database)]
        OBJ[(Object Storage)]
        LOG[Security Logging Pipeline]
    end

    subgraph TB4[External Services]
        PAY[Payment Gateway]
    end

    U -- F1 --> B
    B -- F2 --> WAF
    WAF -- F3 --> WEB
    WEB -- F4 --> API
    API -- F5 --> AUTH
    API -- F6 --> DB
    API -- F7 --> OBJ
    API -- F8 --> PAY
    API -- F9 --> LOG

